{
  "name": "meteora-ai-lp-trading-system",
  "version": "1.0.0",
  "description": "AI-powered automated liquidity provider for Meteora DLMM + Jupiter Aggregator",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "lint": "eslint . --ext .ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio",
    "pm2:start": "pm2 start ecosystem.config.js",
    "pm2:stop": "pm2 stop ecosystem.config.js",
    "docker:build": "docker-compose build",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f app"
  },
  "keywords": [
    "solana",
    "defi",
    "meteora",
    "dlmm",
    "liquidity-provider",
    "trading-bot",
    "ai-trading",
    "jupiter",
    "typescript"
  ],
  "author": "munkdotid",
  "license": "MIT",
  "dependencies": {
    "@meteora-ag/dlmm": "latest",
    "@prisma/client": "^5.7.0",
    "@solana/web3.js": "^1.87.6",
    "@solana/spl-token": "^0.3.9",
    "@jup-ag/core": "^4.0.0-beta.21",
    "fastify": "^4.24.3",
    "@fastify/websocket": "^8.2.0",
    "@fastify/cors": "^8.4.1",
    "@fastify/rate-limit": "^9.0.1",
    "bullmq": "^4.15.0",
    "ioredis": "^5.3.2",
    "telegraf": "^4.15.0",
    "dotenv": "^16.3.1",
    "winston": "^3.11.0",
    "winston-daily-rotate-file": "^4.7.1",
    "zod": "^3.22.4",
    "node-cron": "^3.0.3",
    "axios": "^1.6.2",
    "bn.js": "^5.2.1",
    "decimal.js": "^10.4.3",
    "date-fns": "^2.30.0",
    "uuid": "^9.0.1",
    "express": "^4.18.2",
    "socket.io": "^4.7.2",
    "@tensorflow/tfjs": "^4.15.0",
    "@tensorflow/tfjs-node": "^4.15.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.4",
    "@types/bn.js": "^5.1.5",
    "@types/express": "^4.17.21",
    "@types/uuid": "^9.0.7",
    "@types/node-cron": "^3.0.11",
    "@typescript-eslint/eslint-plugin": "^6.14.0",
    "@typescript-eslint/parser": "^6.14.0",
    "eslint": "^8.55.0",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.11",
    "ts-jest": "^29.1.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3",
    "prisma": "^5.7.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
