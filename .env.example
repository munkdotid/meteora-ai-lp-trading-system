# ==========================================
# AI LP TRADING SYSTEM - ENVIRONMENT CONFIG
# ==========================================

# ------------------------------------------
# SYSTEM CONFIGURATION
# ------------------------------------------
NODE_ENV=production
PORT=3000
LOG_LEVEL=info

# ------------------------------------------
# BLOCKCHAIN CONFIGURATION
# ------------------------------------------
# Solana RPC Endpoint
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
# Or use private RPC for better performance:
# SOLANA_RPC_URL=https://your-private-rpc.com

# Wallet Configuration
# OPTION 1: Direct private key (not recommended for production)
# SOLANA_WALLET_PRIVATE_KEY=your_base58_private_key_here

# OPTION 2: Encrypted key from Vault/KMS (recommended)
# VAULT_ADDR=https://vault.your-domain.com
# VAULT_TOKEN=your_vault_token
# VAULT_SECRET_PATH=secret/meteora-bot/wallet

# OPTION 3: File-based key (with file permissions 600)
WALLET_KEY_PATH=./secrets/wallet-key.json

# ------------------------------------------
# METEORA CONFIGURATION
# ------------------------------------------
METEORA_API_ENDPOINT=https://dlmm-api.meteora.ag
METEORA_PROGRAM_ID=LBUZKhRxPF3XUpBiwKfXZgZccm4iP2Vvp1w27uWYipP

# ------------------------------------------
# JUPITER CONFIGURATION
# ------------------------------------------
JUPITER_API_URL=https://quote-api.jup.ag/v6
JUPITER_API_KEY=your_jupiter_api_key_optional
DEFAULT_SLIPPAGE_BPS=50
MAX_SLIPPAGE_BPS=200

# ------------------------------------------
# DATABASE CONFIGURATION
# ------------------------------------------
DATABASE_URL=postgresql://user:password@localhost:5432/meteora_bot
# For Docker:
# DATABASE_URL=postgresql://meteora_user:meteora_pass@db:5432/meteora_bot

# Redis Configuration (for queue, cache, pub/sub)
REDIS_URL=redis://localhost:6379
# For Docker:
# REDIS_URL=redis://redis:6379

# ------------------------------------------
# TELEGRAM BOT CONFIGURATION
# ------------------------------------------
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_from_botfather
TELEGRAM_WEBHOOK_URL=https://your-domain.com/webhook
TELEGRAM_WEBHOOK_SECRET=random_secret_string_for_webhook_validation

# Authorized users (comma-separated Telegram user IDs)
AUTHORIZED_USERS=123456789,987654321

# Admin users (comma-separated, have access to critical commands)
ADMIN_USERS=123456789

# ------------------------------------------
# TRADING CONFIGURATION
# ------------------------------------------
# Maximum number of concurrent positions
MAX_POSITIONS=5

# Maximum percentage of capital per pool (0.20 = 20%)
MAX_PER_POOL=0.20

# Minimum pool age in hours (safety filter)
MIN_POOL_AGE_HOURS=24

# Minimum TVL in USD
MIN_POOL_TVL=500000

# Minimum 24h volume in USD
MIN_VOLUME_24H=100000

# Maximum volatility (0.50 = 50%)
MAX_VOLATILITY=0.50

# Update interval in seconds (180 = 3 minutes)
UPDATE_INTERVAL=180

# Rebalance check interval in seconds
REBALANCE_INTERVAL=180

# AI minimum confidence threshold (0.75 = 75%)
MIN_AI_CONFIDENCE=0.75

# Stop loss percentage per position (0.03 = 3%)
STOP_LOSS_PERCENTAGE=0.03

# Take profit percentage per position (0.05 = 5%)
TAKE_PROFIT_PERCENTAGE=0.05

# Daily loss limit percentage (0.05 = 5%)
DAILY_LOSS_LIMIT=0.05

# Maximum drawdown percentage (0.10 = 10%)
MAX_DRAWDOWN=0.10

# Cash reserve percentage (0.10 = 10%)
CASH_RESERVE=0.10

# ------------------------------------------
# GAS CONFIGURATION
# ------------------------------------------
# Maximum gas price in lamports
MAX_GAS_PRICE=10000

# Priority fee in micro-lamports
PRIORITY_FEE=10000

# Use Jito bundles for MEV protection
USE_JITO_BUNDLES=true
JITO_TIP_AMOUNT=0.0001

# ------------------------------------------
# AI/ML CONFIGURATION
# ------------------------------------------
# Enable AI prediction models
ENABLE_AI_PREDICTION=true

# Model update frequency (in trades)
MODEL_UPDATE_FREQUENCY=100

# Strategy distribution weights (must sum to 1.0)
STRATEGY_WEIGHT_ALPHA=0.30
STRATEGY_WEIGHT_RANGE=0.50
STRATEGY_WEIGHT_MOMENTUM=0.20

# ------------------------------------------
# NOTIFICATION CONFIGURATION
# ------------------------------------------
# Enable Telegram notifications
ENABLE_TELEGRAM_NOTIFICATIONS=true

# Notification thresholds
NOTIFY_PROFIT_THRESHOLD=0.05
NOTIFY_LOSS_THRESHOLD=-0.03
NOTIFY_REBALANCE=true
NOTIFY_ENTRY=true
NOTIFY_EXIT=true
NOTIFY_EMERGENCY=true

# Daily report time (24-hour format)
DAILY_REPORT_TIME=09:00

# ------------------------------------------
# SECURITY CONFIGURATION
# ------------------------------------------
# JWT Secret for API authentication
JWT_SECRET=your_random_jwt_secret_min_32_chars

# Encryption key for sensitive data (32 bytes)
ENCRYPTION_KEY=your_32_byte_encryption_key_here

# IP Whitelist (comma-separated, leave empty to allow all)
IP_WHITELIST=

# Webhook IP Whitelist
WEBHOOK_IP_WHITELIST=

# 2FA Secret (for critical commands)
TWO_FA_SECRET=your_2fa_secret

# ------------------------------------------
# MONITORING CONFIGURATION
# ------------------------------------------
# Health check port
HEALTH_CHECK_PORT=3001

# Metrics endpoint enabled
ENABLE_METRICS=true

# Sentry DSN (for error tracking)
# SENTRY_DSN=https://your-sentry-dsn

# ------------------------------------------
# BACKUP CONFIGURATION
# ------------------------------------------
# Backup enabled
ENABLE_BACKUP=true

# Backup interval (cron expression)
BACKUP_INTERVAL=0 0 * * *

# Backup retention (days)
BACKUP_RETENTION=30

# S3-compatible backup storage
# BACKUP_S3_ENDPOINT=https://s3.amazonaws.com
# BACKUP_S3_BUCKET=meteora-bot-backups
# BACKUP_S3_ACCESS_KEY=your_access_key
# BACKUP_S3_SECRET_KEY=your_secret_key

# ------------------------------------------
# FEATURE FLAGS
# ------------------------------------------
# Enable auto trading (disable for testing)
ENABLE_AUTO_TRADING=true

# Enable auto rebalance
ENABLE_AUTO_REBALANCE=true

# Dry run mode (simulate trades without executing)
DRY_RUN=false

# Debug mode (verbose logging)
DEBUG=false
