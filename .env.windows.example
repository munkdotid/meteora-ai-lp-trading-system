# ==========================================
# Windows Development Environment Configuration
# ==========================================
# Copy this file to .env and configure your settings
# ==========================================

# ==========================================
# APPLICATION SETTINGS
# ==========================================
NODE_ENV=development
APP_NAME=Meteora AI LP Trading Bot
APP_VERSION=1.0.0

# ==========================================
# SOLANA / BLOCKCHAIN (DEVNET FOR TESTING)
# ==========================================
# Use devnet for development!
SOLANA_NETWORK=devnet
SOLANA_RPC_URL=https://api.devnet.solana.com

# Wallet Configuration (Choose ONE method)
# Method 1: Base58 private key string (NOT RECOMMENDED for production)
# SOLANA_WALLET_PRIVATE_KEY=your_private_key_base58_here

# Method 2: Path to keypair file (RECOMMENDED)
# Place your keypair file in secrets/ folder
SOLANA_WALLET_KEY_PATH=.\secrets\wallet-keypair.json

# Method 3: Environment variable file (MOST SECURE)
# Leave blank and the bot will prompt for input

# Jupiter Settings
JUPITER_API_URL=https://quote-api.jup.ag/v6
JUPITER_SLIPPAGE_BPS=50
JUPITER_MAX_AUTO_SLIPPAGE_BPS=300
JUPITER_COMPUTE_UNIT_PRICE_MICRO_LAMPORTS=50000

# Meteora Settings
METEORA_API_URL=https://dlmm-api.meteora.ag
METEORA_PROGRAM_ID=LBUZKhRxPF3XUpBCjp4YzTKgLccjZhTSDM9YRVaF7Dp

# ==========================================
# DATABASE (Docker on Windows)
# ==========================================
DATABASE_URL=postgresql://meteora:meteora123@localhost:5432/meteora_bot?schema=public
DB_HOST=localhost
DB_PORT=5432
DB_USER=meteora
DB_PASSWORD=meteora123
DB_NAME=meteora_bot

# Connection Pool Settings (Windows optimized)
DB_MAX_CONNECTIONS=10
DB_MIN_CONNECTIONS=2
DB_CONNECTION_TIMEOUT=10000
DB_IDLE_TIMEOUT=30000

# ==========================================
# REDIS CACHE (Docker on Windows)
# ==========================================
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Cache Settings
CACHE_TTL_SHORT=300
CACHE_TTL_MEDIUM=1800
CACHE_TTL_LONG=3600
CACHE_TTL_EXTENDED=86400

# ==========================================
# TRADING SETTINGS (SAFE DEFAULTS FOR TESTING)
# ==========================================
# DRY RUN MODE - MUST BE TRUE FOR INITIAL TESTING
DRY_RUN=true

# Initial capital (SOL)
INITIAL_CAPITAL_SOL=0.1

# Position limits
MAX_POSITIONS=2
MAX_POSITION_PERCENTAGE=0.20
MIN_POSITION_SOL=0.01
MAX_POSITION_SOL=1.0

# Trading frequency
TRADING_LOOP_INTERVAL_MS=180000
SCAN_INTERVAL_MS=300000
REBALANCE_CHECK_INTERVAL_MS=60000
POSITION_MONITOR_INTERVAL_MS=30000

# Rate limiting
MIN_TIME_BETWEEN_TRADES_MS=5000
MAX_TRADES_PER_MINUTE=12
MAX_TRADES_PER_HOUR=50

# ==========================================
# AI SETTINGS
# ==========================================
MIN_AI_CONFIDENCE=0.75
MAX_AI_CONFIDENCE=0.95

# Strategy weights
STRATEGY_WEIGHT_ALPHA=0.30
STRATEGY_WEIGHT_RANGE=0.50
STRATEGY_WEIGHT_MOMENTUM=0.20

# Volatility settings
VOLATILITY_WINDOW_MS=300000
VOLATILITY_THRESHOLD_LOW=0.15
VOLATILITY_THRESHOLD_HIGH=0.45

# ==========================================
# RISK MANAGEMENT (CONSERVATIVE FOR DEV)
# ==========================================
MAX_DAILY_LOSS_PERCENTAGE=0.03
MAX_TOTAL_DRAWDOWN_PERCENTAGE=0.08
MAX_VOLATILITY_SPIKE_MULTIPLIER=2.5
MAX_GAS_PRICE_SOL=0.005
MAX_POOL_AGE_HOURS=168
MIN_POOL_TVL_USD=10000
MIN_POOL_VOLUME_24H_USD=1000

# Circuit breakers
CIRCUIT_BREAKER_ENABLED=true
CIRCUIT_BREAKER_DAILY_LOSS=true
CIRCUIT_BREAKER_DRAWDOWN=true
CIRCUIT_BREAKER_GAS_SPIKE=true
CIRCUIT_BREAKER_TVL_CRASH=true
CIRCUIT_BREAKER_VOLATILITY=true
CIRCUIT_BREAKER_API_FAILURE=true

# ==========================================
# TELEGRAM (OPTIONAL)
# ==========================================
# Leave blank if not using Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=your_webhook_secret_here
TELEGRAM_WEBHOOK_URL=
TELEGRAM_WEBHOOK_PORT=3000

# Authorized users (comma-separated user IDs)
# Get your user ID from @userinfobot
TELEGRAM_AUTHORIZED_USERS=

# Notifications
TELEGRAM_NOTIFICATION_PROFIT_ENABLED=true
TELEGRAM_NOTIFICATION_PROFIT_THRESHOLD=0.05
TELEGRAM_NOTIFICATION_LOSS_ENABLED=true
TELEGRAM_NOTIFICATION_LOSS_THRESHOLD=-0.03
TELEGRAM_NOTIFICATION_ENTRY_ENABLED=true
TELEGRAM_NOTIFICATION_EXIT_ENABLED=true
TELEGRAM_NOTIFICATION_REBALANCE_ENABLED=true
TELEGRAM_NOTIFICATION_EMERGENCY_ENABLED=true

# ==========================================
# LOGGING (Windows paths)
# ==========================================
LOG_LEVEL=debug
LOG_FILE=.\logs\app.log
LOG_MAX_SIZE=50m
LOG_MAX_FILES=5
LOG_CONSOLE=true
LOG_COLORIZE=true

# ==========================================
# API SERVER (Optional for Windows dev)
# ==========================================
API_PORT=3001
API_HOST=127.0.0.1
API_CORS_ORIGIN=http://localhost:3000
API_RATE_LIMIT_ENABLED=true
API_RATE_LIMIT_WINDOW_MS=60000
API_RATE_LIMIT_MAX_REQUESTS=100

# JWT Authentication
JWT_SECRET=your_jwt_secret_change_in_production
JWT_EXPIRES_IN=1h

# ==========================================
# MONITORING
# ==========================================
HEALTH_CHECK_INTERVAL_MS=30000
METRICS_ENABLED=true
METRICS_PORT=9090

# ==========================================
# WINDOWS SPECIFIC
# ==========================================
# Use forward slashes or escaped backslashes for paths
# Good: ./logs or .\\logs
# Bad: \logs (single backslash)

# Process priority (Windows)
PROCESS_PRIORITY=normal

# Windows service settings
WINDOWS_SERVICE_NAME=MeteoraAIBot
WINDOWS_SERVICE_DISPLAY_NAME=Meteora AI LP Trading Bot

# ==========================================
# DEVELOPMENT ONLY
# ==========================================
# These should NEVER be enabled in production
DEBUG_MODE=true
VERBOSE_LOGGING=true
SIMULATE_TRADES=false
MOCK_BLOCKCHAIN=false

# ==========================================
# NOTES
# ==========================================
# 1. Always use DRY_RUN=true for first tests
# 2. Start with small amounts (0.1 SOL)
# 3. Use devnet until comfortable
# 4. Check logs regularly
# 5. Monitor Telegram notifications
# 6. Keep wallet key secure in secrets/ folder
# ==========================================
